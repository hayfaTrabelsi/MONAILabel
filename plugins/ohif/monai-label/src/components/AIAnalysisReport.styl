.aiAnalysisReport {
  padding: 15px;
  background-color: #f9f9f9;
  border-radius: 4px;
  font-family: Arial, sans-serif;
}

.report-header {
  margin-bottom: 15px;
  border-bottom: 1px solid #ddd;
  padding-bottom: 10px;
}

.report-header h3 {
  margin: 0;
  color: #333;
  font-size: 16px;
}

.report-content .section {
  margin-bottom: 20px;
}

.report-content .section h4 {
  margin: 0 0 10px 0;
  color: #555;
  font-size: 14px;
  font-weight: 600;
}

.dr-grade-section {
  display: flex;
  align-items: center;
  gap: 20px;
  padding: 15px;
  background-color: #fff;
  border-radius: 4px;
  border: 1px solid #e0e0e0;
}

.grade-display {
  display: flex;
  align-items: center;
  gap: 10px;
}

.grade-number {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 4px;
  color: white;
  font-weight: bold;
  font-size: 18px;
}

.grade-label {
  font-size: 16px;
  font-weight: 500;
  color: #333;
}

.confidence-meter {
  flex: 1;
  min-width: 200px;
}

.confidence-label {
  font-size: 12px;
  color: #777;
  margin-bottom: 5px;
}

.confidence-bar-container {
  width: 100%;
  height: 20px;
  background-color: #e0e0e0;
  border-radius: 10px;
  overflow: hidden;
  position: relative;
}

.confidence-bar {
  height: 100%;
  transition: width 0.3s ease;
  border-radius: 10px;
}

.confidence-value {
  font-size: 12px;
  font-weight: 500;
  color: #333;
  text-align: right;
  margin-top: 3px;
}

.probabilities-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.probability-item {
  display: flex;
  align-items: center;
  gap: 15px;
  padding: 10px;
  background-color: #fff;
  border-radius: 4px;
  border: 1px solid #e0e0e0;
}

.probability-label {
  display: flex;
  align-items: center;
  gap: 8px;
  flex: 1;
  min-width: 120px;
}

.color-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  display: inline-block;
}

.label-name {
  font-size: 13px;
  color: #333;
}

.probability-bar-container {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 2;
}

.probability-bar {
  height: 16px;
  transition: width 0.3s ease;
  border-radius: 2px;
}

.probability-value {
  font-size: 12px;
  font-weight: 500;
  color: #333;
  min-width: 45px;
  text-align: right;
}

.label-info-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 10px;
}

.label-info-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px;
  background-color: #fff;
  border-radius: 4px;
  border: 1px solid #e0e0e0;
}

.color-square {
  width: 24px;
  height: 24px;
  border-radius: 3px;
}

.label-details {
  display: flex;
  flex-direction: column;
  gap: 3px;
}

.label-name {
  font-size: 13px;
  font-weight: 500;
  color: #333;
}

.label-color {
  font-size: 11px;
  color: #777;
}
